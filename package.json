{
  "name": "test",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.test.scheduler",
    "productName": "TaskScheduler",
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "dist/**/*",
      "src/ui/**/*",
      "src/assets/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "src/assets/tray.png",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "src/assets/tray.png",
      "category": "Utility"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "src/assets/tray.png"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-notifier": "^8.0.5",
    "@types/node-schedule": "^2.1.8",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "node-notifier": "^10.0.1",
    "node-schedule": "^2.1.1"
  }
}
